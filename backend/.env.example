DJANGO_SECRET_KEY=replace-with-a-django-only-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
# Cookie Secure, SSL redirect and HSTS derive safely from DJANGO_DEBUG.
# Override them only when the deployment requires different behavior.
DJANGO_TRUST_X_FORWARDED_PROTO=False

DATABASE_URL=postgresql://user:password@host:5432/database

SUPABASE_URL=https://project-ref.supabase.co
# Optional and backend-only in this architecture.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=sb_secret_replace_me
SUPABASE_PRIVATE_STORAGE_BUCKET=private
SUPABASE_SIGNED_URL_TTL_SECONDS=60
PRIVATE_STORAGE_REQUEST_MAX_BYTES=4096
